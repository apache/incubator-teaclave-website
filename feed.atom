    <entry>
        <title type="html"><![CDATA[Announcing Apache Teaclave (incubating) 0.2.0]]></title>
        <id>https://teaclave.apache.org/blog/2021-03-02-announcing-teaclave-0-2-0/</id>
        <link href="https://teaclave.apache.org/blog/2021-03-02-announcing-teaclave-0-2-0/">
        </link>
        <updated>2021-03-02T00:00:00.000Z</updated>
        <summary type="html"><![CDATA[$ cd incubator-teaclave
$ docker run --rm -v $(pwd):/teaclave -w /teaclave \
  -it teaclave/teaclave-build-ubuntu-1804-sgx-2.9.1:latest \
   bash -c ". /root/.cargo/env && \
     . /opt/sgxsdk/environment && \
     mkdir -p build && cd build && \
     cmake -DTEST_MODE=ON .. && \
     make"
`]]></summary>
    </entry>
